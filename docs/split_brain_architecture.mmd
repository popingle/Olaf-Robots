graph TB
    subgraph Locomotion_Brain [Locomotion Brain - Raspberry Pi Zero 2W]
        direction TB
        RL[RL Walking Policy]
        IMU[IMU Sensor Data]
        Gait[Gait State Machine]
        Balance[Balance Correction]
        
        IMU --> Balance
        RL --> Gait
        Gait --> Balance
    end

    subgraph Expression_Brain [Expression_Brain - ESP32-S3]
        direction TB
        Personality[Personality Engine]
        LED[Dual LED Eye Displays]
        Audio[I2S Audio Output]
        Head[Head Servo Actuation]
        Driver[2N2222 Driver Stage]
        
        Personality --> LED
        Personality --> Audio
        Personality --> Head
        Head --> Driver
    end

    %% Communication Bus
    Locomotion_Brain <==> |Serial Bus - UART| Expression_Brain

    %% Physical Actuation
    Balance --> |10 DOF| Servos[Leg Servo Control]
    Servos --> Robot[PHYSICAL ROBOT ACTUATION]
    Driver --> Robot
